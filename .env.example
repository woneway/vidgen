MINIMAX_API_KEY=your_api_key_here
MINIMAX_API_HOST=https://api.minimaxi.com

# 抖音自动发布（可选，基于 Playwright 浏览器自动化）
# 首次使用先运行：python scripts/douyin_login.py
DOUYIN_COOKIE_FILE=~/.vidgen/douyin_cookie.json   # cookie 保存路径（可自定义）
CHROME_PATH=                                        # Chrome 路径（留空用内置 Chromium）
CHROME_HEADLESS=false                               # true = 无头模式（服务器部署时用）
